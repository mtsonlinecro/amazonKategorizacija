# Opcionalno. Normalno ne treba mijenjati.
# Za automatski BTG folder stavi folder BTG u root projekta.
# Za automatski mapping stavi mapping_file.xls/xlsx u root projekta.

# BTG_FOLDER_PATH=C:\putanja\do\BTG
# MAPPING_FILE_PATH=C:\putanja\do\mapping_file.xls

# AI fallback je ugašen po defaultu.
# Lakše ga je mijenjati u backend/ai_settings.py.
AI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Opcionalni prijevodni sloj za NL/PL/IE/SE.
# Bolje je ključeve pisati u backend/api_keys.py, ali može i ovdje kao environment primjer.
TRANSLATION_ENABLED=true
TRANSLATION_PROVIDER=auto
DEEPL_API_KEY=
DEEPL_USE_FREE_API=true
GOOGLE_TRANSLATE_API_KEY=
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=
OPENAI_TRANSLATION_MODEL=gpt-4.1-mini
